<Window x:Class="StarLinkPOC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:conv="clr-namespace:StarLinkPOC.Converters"
        mc:Ignorable="d"
        Title="StarLink Camera Viewer"
        Height="700" Width="1150"
        MinHeight="600" MinWidth="920"
        Background="#0D0F14"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Palette -->
        <SolidColorBrush x:Key="BgPanel"     Color="#13161E"/>
        <SolidColorBrush x:Key="BgCard"      Color="#1A1E2A"/>
        <SolidColorBrush x:Key="BgInput"     Color="#0F1117"/>
        <SolidColorBrush x:Key="Accent"      Color="#3D7EFF"/>
        <SolidColorBrush x:Key="AccentHover" Color="#5B93FF"/>
        <SolidColorBrush x:Key="Danger"      Color="#FF4C4C"/>
        <SolidColorBrush x:Key="Border"      Color="#252837"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8EAEE"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#6B7280"/>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,10,0,4"/>
        </Style>

        <!-- TextBox -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="CaretBrush"      Value="{StaticResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PasswordBox -->
        <Style x:Key="InputPassword" TargetType="PasswordBox">
            <Setter Property="Background"      Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="CaretBrush"      Value="{StaticResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Background"         Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"         Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"        Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="Padding"            Value="10,8"/>
            <Setter Property="FontSize"           Value="12"/>
            <Setter Property="FontFamily"         Value="Segoe UI"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1A1E2A"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                        <Setter Property="Padding"    Value="10,7"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize"   Value="12"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252837"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="0,11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#2A2D3A"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger button -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF6B6B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#2A2D3A"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost / small button -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1A1E2A"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  Root: Left settings panel + Right live view              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="310"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════ LEFT PANEL ═══════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,26,22,22">

                    <!-- Title -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="9" Height="9" Fill="{StaticResource Accent}"
                                 Margin="0,0,7,0" VerticalAlignment="Center"/>
                        <TextBlock Text="STARLINK" FontSize="10" FontWeight="Bold"
                                   FontFamily="Segoe UI" Foreground="{StaticResource Accent}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Camera Viewer" FontSize="21" FontWeight="Bold"
                               FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="IP Camera Live Stream Monitor" FontSize="11"
                               FontFamily="Segoe UI" Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,20"/>

                    <Border Height="1" Background="{StaticResource Border}" Margin="0,0,0,16"/>

                    <!-- ── Connection Form ─────────────────────────── -->
                    <TextBlock Text="CONNECTION" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>

                    <!-- Camera Host -->
                    <TextBlock Text="CAMERA HOST / IP" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtHost" Style="{StaticResource InputBox}"
                             Text="{Binding CameraHost, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="e.g. 192.168.1.100"/>

                    <!-- Username + Port side-by-side -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="72"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtUsername" Style="{StaticResource InputBox}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PORT" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtPort" Style="{StaticResource InputBox}"
                                     Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Password -->
                    <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="PwdPassword" Style="{StaticResource InputPassword}"
                                 PasswordChanged="PwdPassword_PasswordChanged"/>

                    <!-- Stream Path Preset dropdown -->
                    <TextBlock Text="STREAM PATH PRESET" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CboPreset"
                              Style="{StaticResource InputCombo}"
                              ItemsSource="{Binding StreamPresets}"
                              SelectedItem="{Binding SelectedPreset}"
                              DisplayMemberPath="Label"/>

                    <!-- Stream Path (editable, auto-filled by preset) -->
                    <TextBlock Text="STREAM PATH (EDITABLE)" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtStreamPath" Style="{StaticResource InputBox}"
                             Text="{Binding StreamPath, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="11"/>

                    <!-- Buttons -->
                    <Button Content="▶  Connect"
                            Style="{StaticResource BtnPrimary}"
                            Command="{Binding ConnectCommand}"
                            Margin="0,18,0,8"/>
                    <Button Content="■  Disconnect"
                            Style="{StaticResource BtnDanger}"
                            Command="{Binding DisconnectCommand}"/>

                    <Border Height="1" Background="{StaticResource Border}" Margin="0,20,0,16"/>

                    <!-- ── Status ───────────────────────────────────── -->
                    <TextBlock Text="STATUS" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="14,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                           FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Spinner while connecting -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                        Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVis}}">
                                <Ellipse Width="14" Height="14"
                                         Stroke="{StaticResource Accent}" StrokeThickness="2"
                                         StrokeDashArray="3 1"
                                         RenderTransformOrigin="0.5,0.5" Margin="0,0,8,0">
                                    <Ellipse.RenderTransform><RotateTransform/></Ellipse.RenderTransform>
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                From="0" To="360" Duration="0:0:1"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Establishing connection…" FontSize="11"
                                           FontFamily="Segoe UI" Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Resolved URL shown when connecting/connected -->
                            <TextBlock Text="{Binding ResolvedUrl}" FontSize="9"
                                       FontFamily="Consolas" Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap" Margin="0,6,0,0"
                                       Visibility="{Binding ResolvedUrl, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Diagnostics Log ──────────────────────────── -->
                    <Border Background="{StaticResource BgCard}" CornerRadius="8"
                            Padding="12,10" Margin="0,12,0,0"
                            Visibility="{Binding HasDiagnostics, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="DIAGNOSTICS" Style="{StaticResource FieldLabel}"
                                           Margin="0" VerticalAlignment="Center"/>
                                <Button Content="Clear" Style="{StaticResource BtnGhost}"
                                        Command="{Binding ClearDiagnosticsCommand}"
                                        HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBox Text="{Binding DiagnosticsLog, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="10" FontFamily="Consolas"
                                     Foreground="#9CA3AF" TextWrapping="Wrap"
                                     MaxHeight="200"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════ RIGHT LIVE VIEW ═══════════════════════════ -->
        <Grid Grid.Column="1" Background="#080A0F">

            <!-- VideoView — MediaPlayer set in code-behind -->
            <vlc:VideoView x:Name="VideoView" Background="Black"
                           Loaded="VideoView_Loaded"/>

            <!-- No-signal overlay -->
            <Grid Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0A0C12" Offset="0"/>
                        <GradientStop Color="#0F1219" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- Scanlines -->
                <Rectangle Opacity="0.03">
                    <Rectangle.Fill>
                        <DrawingBrush TileMode="Tile" ViewportUnits="Absolute" Viewport="0,0,2,4">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="White">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,2,1"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Viewbox Width="68" Height="68" Margin="0,0,0,18">
                        <Canvas Width="64" Height="64">
                            <Rectangle Canvas.Left="4" Canvas.Top="16" Width="56" Height="36"
                                       RadiusX="6" RadiusY="6"
                                       Fill="#1A1E2A" Stroke="#252837" StrokeThickness="1.5"/>
                            <Ellipse Canvas.Left="18" Canvas.Top="22" Width="24" Height="24"
                                     Fill="#0F1117" Stroke="#3D7EFF" StrokeThickness="1.5"/>
                            <Ellipse Canvas.Left="24" Canvas.Top="28" Width="12" Height="12"
                                     Fill="#1A2540"/>
                            <Rectangle Canvas.Left="20" Canvas.Top="10" Width="14" Height="8"
                                       RadiusX="3" RadiusY="3"
                                       Fill="#1A1E2A" Stroke="#252837" StrokeThickness="1"/>
                            <Ellipse Canvas.Left="48" Canvas.Top="19" Width="7" Height="7"
                                     Fill="#FF4C4C"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="NO SIGNAL" FontSize="26" FontWeight="Bold"
                               FontFamily="Segoe UI" Foreground="#1E2535"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Enter camera credentials and click Connect"
                               FontSize="12" FontFamily="Segoe UI" Foreground="#2A3045"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- LIVE badge -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14"
                    CornerRadius="4" Padding="10,5"
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                <Border.Background><SolidColorBrush Color="#CC000000"/></Border.Background>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#FF4C4C" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.2" Duration="0:0:0.8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="LIVE" FontSize="11" FontWeight="Bold"
                               FontFamily="Segoe UI" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Camera host badge (bottom-left) -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="14"
                    CornerRadius="4" Padding="10,5"
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                <Border.Background><SolidColorBrush Color="#CC000000"/></Border.Background>
                <TextBlock Text="{Binding CameraHost}" FontSize="11"
                           FontFamily="Consolas" Foreground="#AAAAAA"/>
            </Border>
        </Grid>
    </Grid>
</Window>
